# Huiyin Config Template - copy to .env and fill in your own values

# LLM Provider: deepseek | gemini | mimo | openai_compat
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

MIMO_API_KEY=
MIMO_MODEL=mimo-v2-pro
MIMO_BASE_URL=https://api.mimo-v2.com/v1

OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_MODEL=gpt-4o

# Channel: cli | telegram | wechat
CHANNEL=cli

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DATA_DIR=./data
LOG_LEVEL=INFO
